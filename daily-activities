#!/usr/bin/env bash
# Run the daily personal activity and backup jobs.
#
# activities.py already refreshes/queries browsing_history.py, so do not run
# browsing_history.py separately from this wrapper.

set -uo pipefail

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/bin:/home/sanand/.local/bin:/home/sanand/.local/share/mise/shims:/home/sanand/bin"
export PATH

ENV_FILE="/home/sanand/code/scripts/.env"
UV="${DAILY_ACTIVITIES_UV:-/home/sanand/.local/bin/uv}"
LOCK_DIR="${DAILY_ACTIVITIES_LOCK_DIR:-$HOME/.cache/sanand-scripts/daily-activities}"
LOCK_FILE="$LOCK_DIR/run.lock"
RCLONE="${DAILY_ACTIVITIES_RCLONE:-rclone}"
RSYNC="${DAILY_ACTIVITIES_RSYNC:-rsync}"
OPEN_TABS_DIR="${DAILY_ACTIVITIES_OPEN_TABS_DIR:-$HOME/Documents/data/open-tabs}"
EDGE_TABS_PROFILE="${DAILY_ACTIVITIES_EDGE_TABS_PROFILE:-$HOME/.config/microsoft-edge}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export DAILY_ACTIVITIES=1
export DAILY_ACTIVITIES_QUIET="${DAILY_ACTIVITIES_QUIET:-1}"
export RCLONE_CONFIG="${RCLONE_CONFIG:-$XDG_CONFIG_HOME/rclone/rclone.conf}"
export _RCLONE_BISYNC_OPTIONS='--create-empty-src-dirs --slow-hash-sync-only --fast-list --size-only --checkers 16 --transfers 8 --resilient --metadata --fix-case --exclude "**/node_modules/**" --exclude "**/__pycache__/**" --exclude "**/localdata/**"'
RCLONE_BISYNC_ARGS=(
  --create-empty-src-dirs
  --slow-hash-sync-only
  --fast-list
  --size-only
  --checkers
  16
  --transfers
  8
  --resilient
  --metadata
  --fix-case
  --exclude "**/node_modules/**"
  --exclude "**/__pycache__/**"
  --exclude "**/localdata/**"
)

mkdir -p "$LOCK_DIR"

log() {
  printf '%s daily-activities: %s\n' "$(date --iso-8601=seconds)" "$*" >&2
}

run_job() {
  local name="$1"
  shift
  local start end status elapsed

  start="$(date +%s)"
  log "start $name: $*"
  "$@"
  status=$?
  end="$(date +%s)"
  elapsed=$((end - start))

  if [[ "$status" -eq 0 ]]; then
    log "ok $name (${elapsed}s)"
  else
    log "failed $name exit=$status (${elapsed}s)"
  fi
  return "$status"
}

find_ssh_agent() {
  local uid candidate
  uid="$(id -u)"
  for candidate in \
    "/run/user/$uid/keyring/ssh" \
    "/run/user/$uid/gnupg/S.gpg-agent.ssh" \
    "$HOME/.gnupg/S.gpg-agent.ssh"; do
    [[ -S "$candidate" ]] && printf '%s\n' "$candidate" && return 0
  done
  return 1
}

expose_service_environment() {
  local ssh_agent

  if [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK:-}" ]]; then
    log "using SSH_AUTH_SOCK=$SSH_AUTH_SOCK"
  else
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
      log "SSH_AUTH_SOCK is not a socket: $SSH_AUTH_SOCK"
    fi
    ssh_agent="$(find_ssh_agent || true)"
    if [[ -n "$ssh_agent" ]]; then
      export SSH_AUTH_SOCK="$ssh_agent"
      log "using SSH_AUTH_SOCK=$SSH_AUTH_SOCK"
    else
      log "SSH_AUTH_SOCK not found; rsync over SSH may require an unencrypted key or imported agent environment"
    fi
  fi

  if [[ -r "$RCLONE_CONFIG" ]]; then
    log "using RCLONE_CONFIG=$RCLONE_CONFIG"
  else
    log "RCLONE_CONFIG not readable: $RCLONE_CONFIG"
  fi
}

is_unmetered_connection() {
  local found=0 device type state metered

  if [[ "${DAILY_ACTIVITIES_ALLOW_METERED:-}" == "1" ]]; then
    log "metered-network check overridden by DAILY_ACTIVITIES_ALLOW_METERED=1"
    return 0
  fi

  if ! command -v nmcli >/dev/null; then
    log "nmcli not found; treating network as metered/unknown"
    return 1
  fi

  while IFS=: read -r device type state; do
    [[ "$state" == connected* ]] || continue
    [[ "$type" == "wifi" || "$type" == "ethernet" ]] || continue
    found=1
    metered="$(nmcli -g GENERAL.METERED device show "$device" 2>/dev/null | head -n 1)"
    log "network $device ($type) metered=$metered"
    case "$metered" in
      yes*) return 1 ;;
      no*) return 0 ;;
    esac
  done < <(nmcli -t -f DEVICE,TYPE,STATE device status)

  if [[ "$found" -eq 0 ]]; then
    log "no connected wifi/ethernet device found; treating network as metered/unknown"
  else
    log "connected network metered status is unknown"
  fi
  return 1
}

run_unmetered_job() {
  local name="$1"
  shift

  if ! is_unmetered_connection; then
    log "skip $name: metered or unknown connection"
    return 0
  fi
  run_job "$name" "$@"
}

export_open_tabs() {
  local output

  mkdir -p "$OPEN_TABS_DIR"
  output="$OPEN_TABS_DIR/$(date +%F).jsonl"
  "$UV" run /home/sanand/code/scripts/edge_tabs.py --profile "$EDGE_TABS_PROFILE" --json \
    | jaq -c '.timestamp as $t | .windows[] | .id as $w | .tabs[] | {timestamp:$t, window:$w, title, url}' \
    >"$output"
}

if [[ ! -x "$UV" ]]; then
  log "missing executable: $UV"
  exit 127
fi

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
  log "loaded environment from $ENV_FILE"
else
  log "environment file not found: $ENV_FILE"
fi

expose_service_environment

if ! exec 9>"$LOCK_FILE"; then
  log "cannot open lock file: $LOCK_FILE"
  exit 73
fi
if ! flock -n 9; then
  log "another daily-activities run is already active; skipping this run"
  exit 75
fi

failures=0

if [[ "${DAILY_ACTIVITIES_TEST_JOBS:-}" == "open-tabs" ]]; then
  run_job "open-tabs" export_open_tabs || failures=$((failures + 1))
elif [[ -n "${DAILY_ACTIVITIES_TEST_JOBS:-}" ]]; then
  run_job "test-fail" false || failures=$((failures + 1))
  run_job "test-ok" true || failures=$((failures + 1))
else
  run_job "activities" "$UV" run /home/sanand/code/scripts/activities.py || failures=$((failures + 1))
  run_job "open-tabs" export_open_tabs || failures=$((failures + 1))
  run_unmetered_job "backupgoogle" "$UV" run /home/sanand/code/scripts/backupgoogle.py || failures=$((failures + 1))
  run_unmetered_job "backupgoogle-personal" "$UV" run /home/sanand/code/scripts/backupgoogle.py --config-dir /home/sanand/.config/gws-root.node@gmail.com || failures=$((failures + 1))
  run_unmetered_job "backupmeet" "$UV" run /home/sanand/code/scripts/backupmeet.py --yes || failures=$((failures + 1))
  run_job "summary" "$UV" run /home/sanand/code/summary.py || failures=$((failures + 1))
  run_job "summarize-blog" "$UV" run /home/sanand/code/scripts/summarize.py blog || failures=$((failures + 1))
  run_job "summarize-transcript" "$UV" run /home/sanand/code/scripts/summarize.py transcript || failures=$((failures + 1))
  run_unmetered_job "rclone-files" "$RCLONE" bisync "$HOME/r2/files" r2:files "${RCLONE_BISYNC_ARGS[@]}" || failures=$((failures + 1))
  run_unmetered_job "rclone-private" "$RCLONE" bisync "$HOME/r2/private" r2:private "${RCLONE_BISYNC_ARGS[@]}" || failures=$((failures + 1))
  run_unmetered_job "rclone-redirect" "$RCLONE" bisync "$HOME/r2/redirect" r2:redirect "${RCLONE_BISYNC_ARGS[@]}" || failures=$((failures + 1))
  run_unmetered_job "hetznerbackup" "$RSYNC" -az --info=stats2,name1 \
    "$HOME/Documents/audio" \
    "$HOME/Documents/bcg" \
    "$HOME/Documents/books" \
    "$HOME/Documents/calls" \
    "$HOME/Documents/comics" \
    "$HOME/Documents/data" \
    "$HOME/Documents/forms" \
    "$HOME/Documents/gitlab" \
    "$HOME/Documents/infy" \
    "$HOME/Documents/linkedin" \
    "$HOME/Documents/screenplays" \
    "$HOME/Documents/talks" \
    "$HOME/Pictures" \
    hetzner:/home/ || failures=$((failures + 1))
fi

if [[ "$failures" -gt 0 ]]; then
  log "completed with $failures failed job(s)"
  exit 1
fi

log "completed successfully"
