#!/usr/bin/env perl
use strict;
use warnings;

use File::Find qw(find);
use JSON::PP qw(decode_json);

binmode STDOUT, ':encoding(UTF-8)';

my $filter = shift // q{};
my $base = "$ENV{HOME}/.codex/sessions";

exit 0 unless -d $base;

sub indent_block {
    my ($text) = @_;
    $text //= q{};
    $text =~ s/\n/\n    /g;
    return "    $text";
}

sub truncate_middle {
    my ($text) = @_;
    $text //= q{};

    return $text if length($text) <= 500;

    return substr($text, 0, 250) . '...truncated...' . substr($text, -250);
}

sub decode_json_string {
    my ($text) = @_;
    return q{} unless defined $text;

    my $decoded = eval { decode_json(qq{"$text"}) };
    return defined $decoded ? $decoded : q{};
}

sub read_summary {
    my ($path) = @_;

    open my $handle, '<', $path or return (q{}, q{});

    my ($cwd, $message) = (q{}, q{});
    my ($have_cwd, $have_message) = (0, 0);

    while (my $line = <$handle>) {
        if (
            !$have_cwd
            && $line =~ /"type":"session_meta"/
            && $line =~ /"cwd":"((?:\\.|[^"\\])*)"/
        ) {
            $cwd = decode_json_string($1);
            $have_cwd = 1;
        }

        if (
            !$have_message
            && $line =~ /"type":"event_msg"/
            && $line =~ /"type":"user_message","message":"((?:\\.|[^"\\])*)"/
        ) {
            $message = decode_json_string($1);
            $have_message = 1;
        }

        last if $have_cwd && $have_message;
    }

    close $handle;

    return ($cwd, truncate_middle($message));
}

my @files;
find(
    {
        no_chdir => 1,
        wanted => sub {
            return unless -f $_ && /\.jsonl\z/;
            push @files, $File::Find::name;
        },
    },
    $base,
);

for my $logfile (sort { $b cmp $a } @files) {
    my ($cwd, $message) = read_summary($logfile);
    next if $filter ne q{} && index($cwd, $filter) < 0;

    print "# $logfile\n";
    print indent_block($cwd), "\n";
    print indent_block($message), "\n";
}
