#!/usr/bin/env perl
use strict;
use warnings;

use File::Find qw(find);
use JSON::PP qw(decode_json);

binmode STDOUT, ':encoding(UTF-8)';

my $filter = shift // q{};
my $base = "$ENV{HOME}/.codex/sessions";

exit 0 unless -d $base;

sub indent_block {
    my ($text) = @_;
    $text //= q{};
    $text =~ s/\n/\n    /g;
    return "    $text";
}

sub truncate_middle {
    my ($text) = @_;
    $text //= q{};

    return $text if length($text) <= 500;

    return substr($text, 0, 250) . '...truncated...' . substr($text, -250);
}

sub decode_json_string {
    my ($text) = @_;
    return q{} unless defined $text;

    my $decoded = eval { decode_json(qq{"$text"}) };
    return defined $decoded ? $decoded : q{};
}

sub summarize_source {
    my ($text) = @_;
    return q{} unless defined $text && $text ne q{};

    my $decoded = eval { decode_json($text) };
    return $text if !defined $decoded;

    return $decoded if !ref $decoded;

    if (ref $decoded eq 'HASH') {
        return 'subagent'
            if exists $decoded->{subagent};

        return join(' | ', sort keys %{$decoded});
    }

    return ref $decoded;
}

sub read_summary {
    my ($path) = @_;

    open my $handle, '<', $path or return (q{}, q{}, q{});

    my ($cwd, $source, $message) = (q{}, q{}, q{});
    my ($have_cwd, $have_source, $have_message) = (0, 0, 0);

    while (my $line = <$handle>) {
        if ($line =~ /"type":"session_meta"/) {
            my $event = eval { decode_json($line) };
            if (defined $event && ref $event eq 'HASH') {
                my $payload = $event->{payload};
                if (defined $payload && ref $payload eq 'HASH') {
                    if (!$have_cwd && defined $payload->{cwd}) {
                        $cwd = $payload->{cwd};
                        $have_cwd = 1;
                    }

                    if (!$have_source && exists $payload->{source}) {
                        my $raw_source = $payload->{source};
                        if (ref $raw_source) {
                            $source = summarize_source(JSON::PP::encode_json($raw_source));
                        } else {
                            $source = defined $raw_source ? $raw_source : q{};
                        }
                        $have_source = 1;
                    }
                }
            }
        }

        if (
            !$have_message
            && $line =~ /"type":"event_msg"/
            && $line =~ /"type":"user_message","message":"((?:\\.|[^"\\])*)"/
        ) {
            $message = decode_json_string($1);
            $have_message = 1;
        }

        last if $have_cwd && $have_source && $have_message;
    }

    close $handle;

    return ($cwd, $source, truncate_middle($message));
}

my @files;
find(
    {
        no_chdir => 1,
        wanted => sub {
            return unless -f $_ && /\.jsonl\z/;
            push @files, $File::Find::name;
        },
    },
    $base,
);

for my $logfile (sort { $b cmp $a } @files) {
    my ($cwd, $source, $message) = read_summary($logfile);
    next if $filter ne q{} && index($cwd, $filter) < 0;

    print "# $logfile\n";
    print indent_block(($source ne q{} ? "$source | " : q{}) . $cwd), "\n";
    print indent_block($message), "\n\n";
}
