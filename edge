"""Inspect Microsoft Edge tabs and extract a tab's main content as Markdown.

Examples:
  edge tabs
  edge tabs --json | jaq '.tab_count'
  edge md 'article title' | moor
  edge md docs.example.com | xclip -selection clipboard
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import struct
import sys
from contextlib import closing
from collections.abc import Iterator
from dataclasses import dataclass, field
from pathlib import Path
from urllib.parse import urljoin, urlsplit


EDGE_CONFIG = Path.home() / ".config" / "microsoft-edge"
DEFAULT_PROFILES = [Path.home() / ".config" / "microsoft-edge-cdp", EDGE_CONFIG]


@dataclass
class Navigation:
    url: str
    title: str


@dataclass
class Tab:
    id: int
    window_id: int = 0
    visual_index: int = 0
    current_navigation_index: int = 0
    pinned: bool = False
    group: str | None = None
    group_id: tuple[int, int] | None = None
    navigations: dict[int, Navigation] = field(default_factory=dict)

    @property
    def current_navigation(self) -> Navigation | None:
        if self.current_navigation_index in self.navigations:
            return self.navigations[self.current_navigation_index]
        if not self.navigations:
            return None
        return self.navigations[sorted(self.navigations)[-1]]

    @property
    def url(self) -> str:
        navigation = self.current_navigation
        return navigation.url if navigation else ""

    @property
    def title(self) -> str:
        navigation = self.current_navigation
        return navigation.title if navigation else ""


@dataclass
class Window:
    id: int
    selected_tab_index: int = -1
    tabs: list[Tab] = field(default_factory=list)
    profile: Path | None = None


class PickleReader:
    """Read the subset of Chromium Pickle fields used by session navigation commands."""

    def __init__(self, data: bytes, offset: int = 0):
        self.data = data
        self.offset = offset

    def int32(self) -> int:
        value = struct.unpack_from("<i", self.data, self.offset)[0]
        self.offset += 4
        return value

    def uint64(self) -> int:
        value = struct.unpack_from("<Q", self.data, self.offset)[0]
        self.offset += 8
        return value

    def string(self) -> str:
        size = struct.unpack_from("<I", self.data, self.offset)[0]
        self.offset += 4
        value = self.data[self.offset : self.offset + size].decode("utf-8", errors="replace")
        self.offset += size + (-size % 4)
        return value

    def string16(self) -> str:
        chars = struct.unpack_from("<I", self.data, self.offset)[0]
        self.offset += 4
        size = chars * 2
        value = self.data[self.offset : self.offset + size].decode("utf-16-le", errors="replace")
        self.offset += size + (-size % 4)
        return value


def read_commands(data: bytes) -> Iterator[tuple[int, bytes]]:
    if len(data) < 8 or data[:4] != b"SNSS":
        raise ValueError("Not a Chromium SNSS session file")
    version = struct.unpack_from("<I", data, 4)[0]
    if version not in {1, 3}:
        raise ValueError(f"Unsupported SNSS version: {version}")

    offset = 8
    while offset + 3 <= len(data):
        size = struct.unpack_from("<H", data, offset)[0]
        offset += 2
        if size == 0 or offset + size > len(data):
            break
        command_id = data[offset]
        payload_start = offset + 1
        yield command_id, data[payload_start : payload_start + size - 1]
        offset += size


def get_tab(tabs: dict[int, Tab], tab_id: int) -> Tab:
    return tabs.setdefault(tab_id, Tab(tab_id))


def get_window(windows: dict[int, Window], window_id: int) -> Window:
    return windows.setdefault(window_id, Window(window_id))


def parse_snss(data: bytes) -> list[Window]:
    """Return open browser windows and tabs from one Edge/Chromium SNSS file."""

    tabs: dict[int, Tab] = {}
    windows: dict[int, Window] = {}
    closed_tabs: set[int] = set()
    closed_windows: set[int] = set()
    group_titles: dict[tuple[int, int], str] = {}

    for command_id, payload in read_commands(data):
        if command_id == 0 and len(payload) >= 8:  # SetTabWindow
            window_id, tab_id = struct.unpack_from("<ii", payload)
            get_tab(tabs, tab_id).window_id = window_id
            get_window(windows, window_id)
        elif command_id == 2 and len(payload) >= 8:  # SetTabIndexInWindow
            tab_id, index = struct.unpack_from("<ii", payload)
            get_tab(tabs, tab_id).visual_index = index
        elif command_id == 5 and len(payload) >= 8:  # TabNavigationPathPrunedFromBack
            tab_id, index = struct.unpack_from("<ii", payload)
            tab = get_tab(tabs, tab_id)
            tab.navigations = {key: value for key, value in tab.navigations.items() if key < index}
        elif command_id == 6 and len(payload) >= 12:  # UpdateTabNavigation
            reader = PickleReader(payload, 4)  # First uint32 is Pickle payload size.
            tab_id = reader.int32()
            navigation_index = reader.int32()
            url = reader.string()
            title = reader.string16()
            get_tab(tabs, tab_id).navigations[navigation_index] = Navigation(url, title)
        elif command_id == 7 and len(payload) >= 8:  # SetSelectedNavigationIndex
            tab_id, index = struct.unpack_from("<ii", payload)
            get_tab(tabs, tab_id).current_navigation_index = index
        elif command_id == 8 and len(payload) >= 8:  # SetSelectedTabInIndex
            window_id, index = struct.unpack_from("<ii", payload)
            get_window(windows, window_id).selected_tab_index = index
        elif command_id == 11 and len(payload) >= 8:  # TabNavigationPathPrunedFromFront
            tab_id, index = struct.unpack_from("<ii", payload)
            tab = get_tab(tabs, tab_id)
            tab.current_navigation_index = max(-1, tab.current_navigation_index - index)
            tab.navigations = {
                key - index: value
                for key, value in tab.navigations.items()
                if key >= index
            }
        elif command_id == 12 and len(payload) >= 5:  # SetPinnedState
            tab_id, pinned = struct.unpack_from("<i?", payload)
            get_tab(tabs, tab_id).pinned = pinned
        elif command_id == 16 and len(payload) >= 4:  # TabClosed
            closed_tabs.add(struct.unpack_from("<i", payload)[0])
        elif command_id == 17 and len(payload) >= 4:  # WindowClosed
            closed_windows.add(struct.unpack_from("<i", payload)[0])
        elif command_id == 25 and len(payload) >= 25:  # SetTabGroup
            tab_id, high, low, has_group = struct.unpack_from("<i4xQQ?", payload)
            get_tab(tabs, tab_id).group_id = (high, low) if has_group else None
        elif command_id == 27 and len(payload) >= 24:  # SetTabGroupMetadata2
            reader = PickleReader(payload, 4)  # First uint32 is Pickle payload size.
            group_id = (reader.uint64(), reader.uint64())
            group_titles[group_id] = reader.string16()

    for tab in tabs.values():
        tab.group = group_titles.get(tab.group_id) if tab.group_id else None

    live_windows: dict[int, Window] = {}
    for tab in tabs.values():
        if tab.id in closed_tabs or tab.window_id in closed_windows or not tab.window_id or not tab.url:
            continue
        window = get_window(live_windows, tab.window_id)
        window.selected_tab_index = windows.get(tab.window_id, Window(tab.window_id)).selected_tab_index
        window.tabs.append(tab)

    result = [window for window in live_windows.values() if window.tabs]
    for window in result:
        window.tabs.sort(key=lambda tab: (tab.visual_index, tab.id))
    return result


def default_session_file(profile: Path = EDGE_CONFIG) -> Path:
    sessions_dir = profile / "Default" / "Sessions"
    candidates = sorted(sessions_dir.glob("Session_*"), key=lambda path: path.stat().st_mtime)
    if not candidates:
        raise FileNotFoundError(f"No Session_* files found in {sessions_dir}")
    return candidates[-1]


def windows_to_json(
    windows: list[Window],
    source: Path | list[Path],
    cdp_ids: dict[tuple[int, int], str] | None = None,
) -> dict[str, object]:
    return {
        "timestamp": dt.datetime.now(dt.UTC).isoformat(timespec="seconds"),
        "source": [str(path) for path in source] if isinstance(source, list) else str(source),
        "window_count": len(windows),
        "tab_count": sum(len(window.tabs) for window in windows),
        "windows": [
            {
                "id": window.id,
                **({"profile": window.profile.name} if window.profile else {}),
                "selected_tab_index": window.selected_tab_index,
                "tab_count": len(window.tabs),
                "tabs": [
                    {
                        "id": tab.id,
                        "index": index,
                        **(
                            {"cdp_id": cdp_ids[(window.id, tab.visual_index)]}
                            if cdp_ids and (window.id, tab.visual_index) in cdp_ids
                            else {}
                        ),
                        "visual_index": tab.visual_index,
                        "active": index == window.selected_tab_index,
                        "group": tab.group,
                        "pinned": tab.pinned,
                        "title": tab.title,
                        "url": tab.url,
                    }
                    for index, tab in enumerate(window.tabs)
                ],
            }
            for window in windows
        ],
    }


def print_text(windows: list[Window], source: Path | list[Path], urls_only: bool) -> None:
    print(f"# Timestamp: {dt.datetime.now(dt.UTC).isoformat(timespec='seconds')}")
    print(f"# Source: {', '.join(map(str, source)) if isinstance(source, list) else source}")
    print(f"# Windows: {len(windows)}  Tabs: {sum(len(window.tabs) for window in windows)}")
    for window_index, window in enumerate(windows, 1):
        print()
        profile = f", profile {window.profile.name}" if window.profile else ""
        print(f"Window {window_index} (id {window.id}{profile}, {len(window.tabs)} tabs)")
        for tab_index, tab in enumerate(window.tabs, 1):
            active = " *" if tab_index - 1 == window.selected_tab_index else ""
            prefix = "[PIN] " if tab.pinned else ""
            suffix = f" [{tab.group}]" if tab.group else ""
            if urls_only or not tab.title:
                print(f"{tab_index:3d}.{active} {prefix}{tab.url}{suffix}")
            else:
                print(f"{tab_index:3d}.{active} {prefix}{tab.title}{suffix}\n     {tab.url}")


def load_windows(profile: Path, session_file: Path | None) -> tuple[list[Window], Path]:
    source = session_file or default_session_file(profile)
    return parse_snss(source.read_bytes()), source


def is_profile_open(profile: Path) -> bool:
    """Return whether Chromium's profile-owner process is a live Edge browser."""
    try:
        pid = int((profile / "SingletonLock").readlink().name.rsplit("-", 1)[1])
        command = Path(f"/proc/{pid}/cmdline").read_bytes().decode(errors="replace")
    except (FileNotFoundError, PermissionError, ValueError, IndexError):
        return False
    executable = command.split("\0", 1)[0]
    return "microsoft-edge" in executable or executable.endswith("/msedge")


def load_profiles(profiles: list[Path], session_file: Path | None) -> list[tuple[Path, list[Window], Path]]:
    """Load live profiles, or one explicitly requested offline session file."""
    selected = profiles[:1] if session_file else [profile for profile in profiles if is_profile_open(profile)]
    loaded = []
    for profile in selected:
        windows, source = load_windows(profile, session_file)
        for window in windows:
            window.profile = profile
        loaded.append((profile, windows, source))
    return loaded


def find_tabs(windows: list[Window], query: str) -> list[Tab]:
    """Find tabs containing query in their URL, title, or group name."""
    needle = query.casefold()
    return [
        tab
        for window in windows
        for tab in window.tabs
        if any(needle in value.casefold() for value in (tab.url, tab.title, tab.group or ""))
    ]


def resolve_tabs(windows: list[Window], query: str) -> tuple[list[Tab], bool]:
    """Resolve query, preferring a full group-name match as an ordered collection."""
    needle = query.casefold()
    matches = find_tabs(windows, query)
    group = [tab for tab in matches if (tab.group or "").casefold() == needle]
    return (group or matches, bool(group))


def cdp_targets(cdp_url: str) -> list[dict[str, object]]:
    import httpx

    response = httpx.get(f"{cdp_url.rstrip('/')}/json/list", timeout=10)
    response.raise_for_status()
    return [target for target in response.json() if target.get("type") == "page"]


def cdp_tab_ids(cdp_url: str) -> dict[tuple[int, int], str]:
    """Map session (window ID, tab index) pairs to CDP tab target IDs."""
    from http.client import HTTPConnection, HTTPSConnection

    import websocket

    endpoint = urlsplit(cdp_url)
    http = (HTTPSConnection if endpoint.scheme == "https" else HTTPConnection)(endpoint.netloc, timeout=10)
    http.request("GET", f"{endpoint.path.rstrip('/')}/json/version")
    response = http.getresponse()
    if response.status >= 400:
        raise RuntimeError(f"CDP version endpoint returned HTTP {response.status}")
    websocket_url = json.load(response)["webSocketDebuggerUrl"]
    http.close()

    def command(connection: websocket.WebSocket, request_id: int, method: str, params: dict) -> dict:
        connection.send(json.dumps({"id": request_id, "method": method, "params": params}))
        while True:
            result = json.loads(connection.recv())
            if result.get("id") == request_id:
                break
        if "error" in result:
            raise RuntimeError(result["error"]["message"])
        return result["result"]

    with closing(websocket.create_connection(websocket_url, timeout=10, suppress_origin=True)) as connection:
        targets = command(
            connection,
            1,
            "Target.getTargets",
            {"filter": [{"type": "tab", "exclude": False}, {"exclude": True}]},
        )["targetInfos"]
        result = {}
        pending = {}
        request_id = 2
        for target in targets:
            tab_index = target.get("embedderData", {}).get("tabStripIndex")
            if not isinstance(tab_index, int):
                continue
            connection.send(
                json.dumps(
                    {
                        "id": request_id,
                        "method": "Browser.getWindowForTarget",
                        "params": {"targetId": target["targetId"]},
                    }
                )
            )
            pending[request_id] = (target["targetId"], tab_index)
            request_id += 1
        while pending:
            response = json.loads(connection.recv())
            target = pending.pop(response.get("id"), None)
            if target is None:
                continue
            if "error" in response:
                raise RuntimeError(response["error"]["message"])
            target_id, tab_index = target
            result[(response["result"]["windowId"], tab_index)] = target_id
    return result


def tab_html(tab: Tab, cdp_url: str) -> str:
    """Return the current DOM HTML for tab using its CDP page target."""
    import websocket

    targets = [target for target in cdp_targets(cdp_url) if target.get("url") == tab.url]
    titled = [target for target in targets if target.get("title") == tab.title]
    target = (titled or targets or [None])[0]
    if target is None:
        raise RuntimeError(f"Tab is not available over CDP: {tab.title} ({tab.url})")
    websocket_url = target.get("webSocketDebuggerUrl")
    if not isinstance(websocket_url, str):
        raise RuntimeError(f"CDP target has no WebSocket URL: {tab.url}")

    with closing(websocket.create_connection(websocket_url, timeout=10, suppress_origin=True)) as connection:
        connection.send(
            json.dumps(
                {
                    "id": 1,
                    "method": "Runtime.evaluate",
                    "params": {
                        "expression": "document.documentElement.outerHTML",
                        "returnByValue": True,
                    },
                }
            )
        )
        while True:
            response = json.loads(connection.recv())
            if response.get("id") == 1:
                break
    if "error" in response:
        raise RuntimeError(response["error"]["message"])
    return response["result"]["result"]["value"]


def html_to_markdown(html: str, url: str) -> str:
    """Extract readable main content and convert it to clean GitHub-flavored Markdown."""
    from bs4 import BeautifulSoup
    from markdownify import markdownify

    document = BeautifulSoup(html, "html.parser")
    for element in document.select("nav, aside, footer, form, script, style, template, noscript, iframe"):
        element.decompose()
    candidates = document.select("main, article, [role='main'], section")
    content_node = max(candidates, key=lambda node: len(node.get_text(" ", strip=True)), default=document.body)
    content = str(content_node or document)
    soup = BeautifulSoup(content, "html.parser")
    for element in soup.select(
        "script, style, template, noscript, iframe, button, textarea, input, "
        "[hidden], [aria-hidden='true'], .u-display-none, .w-form-done, .w-form-fail"
    ):
        element.decompose()
    for element in soup.select("a[href], img[src]"):
        attribute = "href" if element.name == "a" else "src"
        element[attribute] = urljoin(url, element[attribute])
    for image in soup.select("img"):
        if len(image.get("alt", "").strip()) < 3 or image.get("alt") == "Favicon":
            image.decompose()
    return markdownify(
        str(soup), heading_style="ATX", bullets="-", code_language_callback=lambda _: ""
    ).strip()


def tab_markdown(tab: Tab, cdp_url: str) -> str:
    return html_to_markdown(tab_html(tab, cdp_url), tab.url)


def md_command(queries: list[str], profiles: list[Path] | Path, session_file: Path | None, cdp_url: str) -> int:
    loaded = load_profiles(profiles, session_file) if isinstance(profiles, list) else [(profiles, *load_windows(profiles, session_file))]
    resolved = []
    for query in queries:
        matches = [(profile, tab) for profile, windows, _ in loaded for tab in find_tabs(windows, query)]
        needle = query.casefold()
        groups = [(profile, tab) for profile, tab in matches if (tab.group or "").casefold() == needle]
        group_keys = {(profile, tab.group_id or tab.group) for profile, tab in groups}
        is_group = bool(groups) and len(group_keys) == 1
        resolved.append((query, groups if is_group else matches, is_group))

    missing = [query for query, matches, _ in resolved if not matches]
    ambiguous = [(query, matches) for query, matches, is_group in resolved if len(matches) > 1 and not is_group]
    for query in missing:
        print(f"No tab matches: {query}", file=sys.stderr)
    for index, (query, matches) in enumerate(ambiguous):
        if index:
            print()
        print(f"## {query}\n")
        print("Profile\tTitle\tTab group\tURL")
        for profile, tab in matches:
            print(f"{profile.name}\t{tab.title}\t{tab.group or ''}\t{tab.url}")
    if missing or ambiguous:
        return 1

    tabs: dict[tuple[Path, int, int], Tab] = {}
    for _, matches, _ in resolved:
        for profile, tab in matches:
            tabs.setdefault((profile, tab.window_id, tab.id), tab)
    documents = []
    for tab in tabs.values():
        metadata = [f"# {tab.title or tab.url}", "", f"- URL: {tab.url}"]
        if tab.group:
            metadata.append(f"- Tab group: {tab.group}")
        documents.append("\n".join([*metadata, "", tab_markdown(tab, cdp_url)]))
    print("\n\n---\n\n".join(documents))
    return 0


def add_session_arguments(parser: argparse.ArgumentParser) -> None:
    parser.add_argument(
        "--profile", action="append", type=Path,
        help=f"Edge profile root (repeatable), defaults: {', '.join(map(str, DEFAULT_PROFILES))}",
    )
    parser.add_argument("--file", type=Path, help="Specific SNSS Session_* file to parse")


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    subparsers = parser.add_subparsers(dest="command", required=True)
    tabs_parser = subparsers.add_parser("tabs", help="Print tabs grouped by Edge window")
    add_session_arguments(tabs_parser)
    tabs_parser.add_argument("--json", action="store_true", help="Print JSON instead of text")
    tabs_parser.add_argument("--urls-only", action="store_true", help="Only print tab URLs in text output")
    tabs_parser.add_argument("--cdp-url", help="Add CDP target IDs from this browser endpoint")

    md_parser = subparsers.add_parser("md", help="Extract one matching tab's main content as Markdown")
    md_parser.add_argument(
        "queries", nargs="+", metavar="QUERY", help="Partial title/URL matches or full tab group names"
    )
    add_session_arguments(md_parser)
    md_parser.add_argument("--cdp-url", default="http://localhost:9222", help="CDP HTTP endpoint, default: %(default)s")
    args = parser.parse_args()

    profiles = args.profile or DEFAULT_PROFILES
    if args.command == "md":
        raise SystemExit(md_command(args.queries, profiles, args.file, args.cdp_url))

    loaded = load_profiles(profiles, args.file)
    windows = [window for _, profile_windows, _ in loaded for window in profile_windows]
    sources = [source for _, _, source in loaded]
    if args.json:
        cdp_ids = cdp_tab_ids(args.cdp_url) if args.cdp_url else None
        print(json.dumps(windows_to_json(windows, sources, cdp_ids), indent=2, ensure_ascii=False))
    else:
        print_text(windows, sources, args.urls_only)


if __name__ == "__main__":
    main()
